#!/usr/bin/env sh
# Post-commit hook: report file budget regressions without blocking incremental refactors

# Skip if SKIP_HOOKS is set (for emergency commits)
if [ -n "$SKIP_HOOKS" ]; then
  echo "⚠️  SKIP_HOOKS is set, skipping post-commit checks"
  exit 0
fi

changed_files="$(git diff-tree --root --no-commit-id --name-only -r HEAD | tr '\n' ' ')"
if [ -z "$changed_files" ]; then
  exit 0
fi

echo "📏 Checking file budgets for the latest commit..."
ENTRIX_BIN="./target/debug/entrix"
if [ -x "$ENTRIX_BIN" ]; then
  ENTRIX_CMD="$ENTRIX_BIN"
else
  ENTRIX_CMD="cargo run -q -p entrix --"
fi

if ! sh -c "$ENTRIX_CMD hook file-length \
  --config docs/fitness/file_budgets.pre_commit.json \
  --strict-limit \
  $changed_files"; then
  echo "⚠️  File budget warning: this commit includes oversized staged files."
  echo "    Continue refactoring before push."
fi
