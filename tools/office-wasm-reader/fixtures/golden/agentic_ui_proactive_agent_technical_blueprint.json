      "textBlocks": [
        {
          "path": "slides[6].text[0]",
          "text": "主动式 Agent 的核心循环"
        },
        {
          "path": "slides[6].text[1]",
          "text": "把“主动”拆成 6 个可工程化的阶段，而不是直接让 Agent 自动行动。"
        },
        {
          "path": "slides[6].text[2]",
          "text": "Sense"
        },
        {
          "path": "slides[6].text[3]",
          "text": "收集信号"
        },
        {
          "path": "slides[6].text[4]",
          "text": "事件流 / 连接器 / 用户状态"
        },
        {
          "path": "slides[6].text[5]",
          "text": "Score"
        },
        {
          "path": "slides[6].text[6]",
          "text": "筛选机会"
        },
        {
          "path": "slides[6].text[7]",
          "text": "重要性 × 置信度 × 时机 × 风险"
        },
        {
          "path": "slides[6].text[8]",
          "text": "Suggest"
        },
        {
          "path": "slides[6].text[9]",
          "text": "提出建议"
        },
        {
          "path": "slides[6].text[10]",
          "text": "证据、理由、影响、可选行动"
        },
        {
          "path": "slides[6].text[11]",
          "text": "Negotiate"
        },
        {
          "path": "slides[6].text[12]",
          "text": "协商权限"
        },
        {
          "path": "slides[6].text[13]",
          "text": "计划预览、审批、降低权限"
        },
        {
          "path": "slides[6].text[14]",
          "text": "Act"
        },
        {
          "path": "slides[6].text[15]",
          "text": "执行任务"
        }
      ],
      "title": "主动式 Agent 的核心循环"
    },
    {
      "index": 7,
      "textBlockCount": 36,
      "textBlocks": [
        {
          "path": "slides[7].text[0]",
          "text": "Opportunity Engine：主动介入的技术判定"
        },
        {
          "path": "slides[7].text[1]",
          "text": "核心不是“能发现什么”，而是“什么值得现在告诉用户”。"
        },
        {
          "path": "slides[7].text[2]",
          "text": "Opportunity Score"
        },
        {
          "path": "slides[7].text[3]",
          "text": "S = Impact × Confidence × Urgency × UserFit − Risk − InterruptionCost"
        },
        {
          "path": "slides[7].text[4]",
          "text": "Impact"
        },
        {
          "path": "slides[7].text[5]",
          "text": "潜在收益或损失"
        },
        {
          "path": "slides[7].text[6]",
          "text": "客户流失、收入、项目延期"
        },
        {
          "path": "slides[7].text[7]",
          "text": "Confidence"
        },
        {
          "path": "slides[7].text[8]",
          "text": "证据强度"
        },
        {
          "path": "slides[7].text[9]",
          "text": "多源信号一致、历史相似案例"
        },
        {
          "path": "slides[7].text[10]",
          "text": "Urgency"
        },
        {
          "path": "slides[7].text[11]",
          "text": "时效性"
        },
        {
          "path": "slides[7].text[12]",
          "text": "截止时间、窗口期、风险增长"
        },
        {
          "path": "slides[7].text[13]",
          "text": "UserFit"
        },
        {
          "path": "slides[7].text[14]",
          "text": "用户偏好"
        },
        {
          "path": "slides[7].text[15]",
          "text": "用户常处理、已授权、当前上下文"
        }
      ],
      "title": "Opportunity Engine：主动介入的技术判定"
    },
    {
      "index": 8,
      "textBlockCount": 23,
      "textBlocks": [
        {
          "path": "slides[8].text[0]",
          "text": "Context & Memory：让 Agent 主动但不越界"
        },
        {
          "path": "slides[8].text[1]",
          "text": "上下文工程决定 Agent 看见什么；记忆治理决定 Agent 可以长期记住什么。"
        },
        {
          "path": "slides[8].text[2]",
          "text": "Event Context"
        },
        {
          "path": "slides[8].text[3]",
          "text": "实时信号：邮件、会议、CRM、产品事件、浏览器状态"
        },
        {
          "path": "slides[8].text[4]",
          "text": "Task Context"
        },
        {
          "path": "slides[8].text[5]",
          "text": "当前任务、计划、草稿、工具结果、用户编辑"
        },
        {
          "path": "slides[8].text[6]",
          "text": "Profile Memory"
        },
        {
          "path": "slides[8].text[7]",
          "text": "偏好、角色、项目、常用流程、禁忌与权限"
        },
        {
          "path": "slides[8].text[8]",
          "text": "Context Composer"
        },
        {
          "path": "slides[8].text[9]",
          "text": "1. 信号归一化"
        },
        {
          "path": "slides[8].text[10]",
          "text": "2. 去重与窗口化"
        },
        {
          "path": "slides[8].text[11]",
          "text": "3. 检索相关资料"
        },
        {
          "path": "slides[8].text[12]",
          "text": "4. 组装最小上下文"
        },
        {
          "path": "slides[8].text[13]",
          "text": "5. 标注来源与可信度"
        },
        {
          "path": "slides[8].text[14]",
          "text": "RAG / Search"
        },
        {
          "path": "slides[8].text[15]",
          "text": "文件、知识库、历史记录；必要时用语义检索"
        }
      ],
      "title": "Context & Memory：让 Agent 主动但不越界"
    },
