# ═══════════════════════════════════════════════════════════════════════════
# Routa 环境配置 (Claude Code SDK 模式)
# 基于全量 process.env 扫描生成，按模块分组
# ═══════════════════════════════════════════════════════════════════════════

# ── 1. 数据库 ─────────────────────────────────────────────────────────────
# SQLite 本地模式 (默认，推荐本地开发)
# ROUTA_DB_DRIVER=sqlite
# ROUTA_DB_PATH=routa.db

# PostgreSQL 模式 (Vercel/生产)
# Get your connection string from https://neon.tech or Vercel dashboard
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ── 2. VCS 平台选择 ─────────────────────────────────────────────────────
# Options: github | gitlab (default: github)
# PLATFORM=github

# ── 3. GitHub 集成 ──────────────────────────────────────────────────────
# Required: GitHub personal access token (needs repo webhook admin scope)
# GITHUB_TOKEN=github_pat_...
# Optional: GitHub API custom URL (for GitHub Enterprise)
# GITHUB_API_URL=https://api.github.com
# Optional: Shared HMAC secret for verifying incoming webhook payloads
# GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# GitHub Polling Adapter — Alternative to webhooks for local development
# GITHUB_POLLING_ENABLED=false
# GITHUB_POLLING_INTERVAL=30

# ── 4. GitLab 集成 ──────────────────────────────────────────────────────
# Required when PLATFORM=gitlab: GitLab personal access token (api, read_api, read_repository)
# GITLAB_TOKEN=glpat-...
# GITLAB_URL=https://gitlab.com
# GITLAB_WEBHOOK_SECRET=your-webhook-secret-here

# GitLab Polling Adapter
# GITLAB_POLLING_ENABLED=false
# GITLAB_POLLING_INTERVAL=30

# ── 5. Claude Code SDK / Anthropic API ───────────────────────────────────
# ── 4.5 邮件通知 (SMTP) ────────────────────────────────────────────────
# 可选：配置后系统在任务完成/失败/PR合并等事件时发送邮件通知
# 不配置时系统正常运行，仅输出降级日志
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password-or-app-token
# SMTP_SENDER=noreply@your-domain.com

# ── 5. Claude Code SDK / Anthropic API ───────────────────────────────────
# Required: API authentication token
# ANTHROPIC_AUTH_TOKEN=your-token-here
# Base URL — 默认 https://api.anthropic.com，智谱兼容 API:
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
# API Key (部分 provider 需要，与 AUTH_TOKEN 二选一)
# ANTHROPIC_API_KEY=your-api-key

# Request timeout in milliseconds (default: 55000)
# API_TIMEOUT_MS=3000000

# ── 6. 模型配置 ─────────────────────────────────────────────────────────
# 主模型 (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=glm-5.1
# 小/快模型 (default: glm-4.5-air)
# ANTHROPIC_SMALL_FAST_MODEL=glm-4.5-air
# 分层模型
# ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5-turbo
# ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.1
# ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-5-turbo

# ── 7. OpenCode Agent (Docker/远程) ─────────────────────────────────────
# WORKSPACE_AGENT_PROVIDER=opencode
# WORKSPACE_AGENT_MODEL=glm-5.1
# WORKSPACE_AGENT_MAX_STEPS=50
# OPENCODE_API_KEY=your-opencode-key
# OPENCODE_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
# OPENCODE_MODEL=glm-5.1
# OPENCODE_MODEL_ID=glm-5.1
# OPENCODE_SERVER_URL=http://localhost:3310
# OPENCODE_DIRECTORY=/tmp/opencode
# ROUTA_DOCKER_OPENCODE_IMAGE=routa/opencode-agent:latest

# ── 8. ACP (Agent Communication Protocol) ────────────────────────────────
# ROUTA_ACP_RUNNER_HOST=127.0.0.1
# ROUTA_ACP_RUNNER_PORT=3310
# ROUTA_ACP_RUNNER_URL=http://127.0.0.1:3310
# ROUTA_ACP_SESSION_LEASE_SECONDS=3600
# ROUTA_DEBUG_ACP=false

# ── 9. SDK 模式 ─────────────────────────────────────────────────────────
# 启用 Claude Code SDK 模式 (本地开发推荐开启)
# ROUTA_USE_SDK_MODE=1
# ROUTA_TOOL_MODE=essential
# ROUTA_MODEL=glm-5.1

# ── 10. 服务器配置 ──────────────────────────────────────────────────────
# PORT=3000
# HOST=localhost
# NODE_ENV=development
# ROUTA_BASE_URL=http://localhost:3000
# ROUTA_SERVER_URL=http://localhost:3000
# ROUTA_INTERNAL_API_ORIGIN=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_ROUTA_BACKEND_BASE_URL=http://localhost:3000
# ROUTA_INSTANCE_ID=local-dev

# ── 11. 工作区与 Worktree ───────────────────────────────────────────────
# Git worktree 根目录 (default: ~/.routa/workspace)
# Windows 建议设置到空间充足的盘
# ROUTA_WORKTREE_ROOT=E:\.routa\worktrees
# 默认 workspace ID
# ROUTA_WORKSPACE_ID=default

# ── 12. 看板自动化调优 ──────────────────────────────────────────────────
# 最大事件监听器 (default: 20)
# ROUTA_MAX_LISTENERS=20
# Rate limit 重试延迟 (ms, default: 30000,60000,120000)
# ROUTA_RATE_LIMIT_RETRY_DELAYS=30000,60000,120000
# Session 创建连续失败上限 (default: 3)
# ROUTA_SESSION_RETRY_LIMIT=3
# 断路器冷却时间 (ms, default: 300000 = 5min)
# ROUTA_SESSION_RETRY_RESET_MS=300000
# 断路器最大冷却重置次数 (default: 5)
# ROUTA_CB_MAX_COOLDOWN_RESETS=5
# Stale queue 最大重试次数 (default: 3)
# ROUTA_STALE_MAX_RETRIES=3
# PR 自动创建最大重试次数 (default: 3)
# ROUTA_PR_RETRY_LIMIT=3
# 内存保护阈值 MB (default: 512)
# ROUTA_MEMORY_LIMIT_MB=512

# ── 13. 存储性能 ────────────────────────────────────────────────────────
# Store dedup proxy — "0" 禁用 Promise 合并
# ROUTA_STORE_DEDUP=1
# 慢查询阈值 ms (default: 200, 需 ROUTA_STORE_TIMING=1)
# ROUTA_STORE_SLOW_THRESHOLD_MS=200
# 启用存储计时
# ROUTA_STORE_TIMING=0
# DB 慢查询阈值 ms
# ROUTA_DB_SLOW_THRESHOLD_MS=200
# 启用 DB 计时
# ROUTA_DB_TIMING=0

# ── 14. API 性能监控 ────────────────────────────────────────────────────
# 慢 API 阈值 ms (default: 1000)
# ROUTA_SLOW_API_THRESHOLD_MS=1000
# 全量 API 计时日志
# ROUTA_API_TIMING_LOG_ALL=false
# 性能面板
# ROUTA_PERF_DASHBOARD=false
# ROUTA_PERF_DISABLED=false

# ── 15. OpenTelemetry ───────────────────────────────────────────────────
# ROUTA_OTEL_ENABLED=false
# ROUTA_OTEL_OUTPUT_PATH=./traces
# ROUTA_OTEL_SAMPLE_RATIO=1.0
# ROUTA_OTEL_SERVICE_NAME=routa-nextjs

# ── 16. 构建与部署 ──────────────────────────────────────────────────────
# 静态构建模式 (default: "1")
# ROUTA_BUILD_STATIC=1
# 跳过运行时服务初始化
# ROUTA_SKIP_RUNTIME_SERVICES=false
# 运行时服务延迟 ms
# ROUTA_RUNTIME_SERVICES_DELAY_MS=0
# Feature tree CLI 路径
# ROUTA_FEATURE_TREE_CLI_PATH=
# Specialists 资源目录
# ROUTA_SPECIALISTS_RESOURCE_DIR=

# ── 17. 其他 Provider ───────────────────────────────────────────────────
# OpenAI 兼容 API
# OPENAI_API_KEY=your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# 智谱 API (非 Anthropic 兼容)
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Qoder
# QODER_BIN=/path/to/qoder

# ── 18. 测试与调试 ──────────────────────────────────────────────────────
# Harness 审计 provider (default: codex)
# HARNESS_INSTRUCTION_AUDIT_PROVIDER=codex
# 页面快照 fixture 模式
# PAGE_SNAPSHOT_FIXTURE_MODE=false
# Gate 模型
# GATE_MODEL=
# Claude 配置目录
# CLAUDE_CONFIG_DIR=/tmp/.claude
# Skills API URL (default: https://skills.sh)
# SKILLS_API_URL=https://skills.sh
