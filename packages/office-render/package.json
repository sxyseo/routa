{
  "name": "@autodev/office-render",
  "version": "0.1.1",
  "description": "Standalone React components for DOCX, PPTX, and XLSX document preview — framework-agnostic, no Next.js required.",
  "type": "module",
  "license": "MIT",
  "author": "Phodal Huang",
  "homepage": "https://github.com/phodal/routa#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phodal/routa.git",
    "directory": "packages/office-render"
  },
  "keywords": [
    "office",
    "docx",
    "pptx",
    "xlsx",
    "react",
    "preview",
    "wasm",
    "spreadsheet",
    "presentation",
    "word"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./presentation-cursor-runtime": {
      "import": "./dist/presentation-cursor-runtime.js",
      "types": "./dist/presentation-cursor-runtime.d.ts"
    },
    "./spreadsheet-canvas.worker": {
      "import": "./dist/spreadsheet-canvas.worker.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@chenglou/pretext": ">=0.0.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@chenglou/pretext": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "esbuild-plugin-css-modules": "^0.3.0",
    "tsup": "^8.5.0",
    "typescript": "5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
