{
  "name": "@autodev/office",
  "version": "0.1.1",
  "description": "Office document reader powered by .NET browser-wasm — reads DOCX, PPTX, XLSX and returns protobuf bytes.",
  "type": "module",
  "license": "MIT",
  "author": "Phodal Huang",
  "homepage": "https://github.com/phodal/routa#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phodal/routa.git",
    "directory": "packages/office"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "office",
    "docx",
    "pptx",
    "xlsx",
    "cursor",
    "canvas",
    "wasm",
    "dotnet",
    "protobuf"
  ],
  "bin": {
    "autodev-office": "dist/cli.js",
    "office-canvas": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cursor-canvas": {
      "import": "./dist/cursor-canvas.js",
      "types": "./dist/cursor-canvas.d.ts"
    },
    "./office-canvas": {
      "import": "./dist/office-canvas.js",
      "types": "./dist/office-canvas.d.ts"
    }
  },
  "files": [
    "dist",
    "wasm",
    "README.md"
  ],
  "scripts": {
    "build:ts": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
