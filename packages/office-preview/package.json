{
  "name": "@routa/office-preview",
  "version": "0.1.0",
  "description": "Standalone React components for DOCX, PPTX, and XLSX document preview — no Next.js required.",
  "type": "module",
  "license": "MIT",
  "author": "Phodal Huang",
  "homepage": "https://github.com/phodal/routa#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phodal/routa.git",
    "directory": "packages/office-preview"
  },
  "keywords": [
    "office",
    "docx",
    "pptx",
    "xlsx",
    "react",
    "preview",
    "wasm"
  ],
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.css",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
