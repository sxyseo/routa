# ============================================================
# Routa Docker 开发环境配置模板
# ============================================================
# 使用说明：
#   1. 复制本文件为 .env.docker（cp .env.docker.example .env.docker）
#   2. 填写下方必填项
#   3. 运行 npm run docker:dev 启动服务
# ============================================================

# ── 必填：LLM 认证 ──────────────────────────────────────────
# Anthropic API Token（必填，缺失则容器启动失败）
ANTHROPIC_AUTH_TOKEN=your-token-here

# ── 可选：API 端点 ─────────────────────────────────────────
# 自定义 Anthropic 兼容 API 地址（如 BigModel 等）
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic

# ── 可选：平台选择 ─────────────────────────────────────────
# 代码托管平台：github（默认）或 gitlab
# PLATFORM=github

# ── 可选：GitHub 集成 ──────────────────────────────────────
# GitHub 个人访问令牌（需要 repo webhook admin 权限）
# GITHUB_TOKEN=github_pat_...
# Webhook HMAC 密钥（用于验证传入 webhook 负载）
# GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
# 轮询模式（webhook 替代方案，本地开发推荐）
# GITHUB_POLLING_ENABLED=true
# GITHUB_POLLING_INTERVAL=30

# ── 可选：模型配置 ─────────────────────────────────────────
# 自定义模型名称（覆盖默认 Claude 模型）
# ANTHROPIC_MODEL=glm-5.1
# ANTHROPIC_SMALL_FAST_MODEL=glm-5.1
